# ============================================================================
# MedSync — Centralized Environment Configuration
# ============================================================================
# This is the single source of truth for ALL services (Compose + frontend).
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ============================================================================

# ─── Platform Secrets ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=7d

# ─── Kafka / Redis ──────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
REDIS_HOST=redis
REDIS_PORT=6379

# ─── MongoDB (local via Compose by default) ─────────────────────────────────
# Compose spins up a local mongo container — no Atlas creds needed for dev.
# To use Atlas instead, set MONGO_BASE to your Atlas connection string.
MONGO_BASE=mongodb://mongo:27017

# Optional: MongoDB Atlas Cloud override
# MONGODB_USER=your_atlas_username
# MONGODB_PASSWORD=your_atlas_password
# MONGODB_ATLAS_CLUSTER=your_cluster.mongodb.net

# ─── Service Ports (host mappings) ──────────────────────────────────────────
AUTH_PORT=5000
PATIENT_PORT=3001
DOCTOR_PORT=3002
APPOINTMENT_PORT=3003
TELEMEDICINE_PORT=3004
PAYMENT_PORT=3005
NOTIFICATION_PORT=3006
AI_PORT=3007
FRONTEND_PORT=3000

# ─── Cross-service URLs (Docker network) ────────────────────────────────────
DOCTOR_SERVICE_URL=http://doctor-management:3002
APPOINTMENT_SERVICE_URL=http://appointment:3003
FRONTEND_URL=http://localhost:3000

# ─── Admin bootstrap (seeded into auth DB on first run) ─────────────────────
ADMIN_EMAIL=admin@medsync.com
ADMIN_PASSWORD=change_me_strong_password

# ─── External APIs ──────────────────────────────────────────────────────────

# AI Symptom Checker (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Notifications (Email)
EMAIL_USER=medsync.care@gmail.com
EMAIL_PASS=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Notifications (Twilio SMS)
TWILIO_SID=AC...
TWILIO_AUTH_TOKEN=your_authToken
TWILIO_FROM=+123456789

# Telemedicine (Agora)
AGORA_APP_ID=your_appId
AGORA_APP_CERTIFICATE=your_appCertificate

# ─── Frontend (NEXT_PUBLIC_* vars exposed to the browser) ───────────────────
# In Compose, the browser hits the host ports, so URLs target localhost.
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:5000/api/auth
NEXT_PUBLIC_PATIENT_SERVICE_URL=http://localhost:3001/api/patients
NEXT_PUBLIC_DOCTOR_SERVICE_URL=http://localhost:3002/api/doctors
NEXT_PUBLIC_APPOINTMENT_SERVICE_URL=http://localhost:3003/api/appointments
NEXT_PUBLIC_TELEMEDICINE_SERVICE_URL=http://localhost:3004/api/sessions
NEXT_PUBLIC_PAYMENT_SERVICE_URL=http://localhost:3005/api/payments
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://localhost:3006/api/notify
NEXT_PUBLIC_SYMPTOM_CHECKER_URL=http://localhost:3007/api/symptom-checker
