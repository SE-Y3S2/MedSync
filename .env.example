# --- MedSync Platform Infrastructure ---
JWT_SECRET=your_jwt_secret_here
KAFKA_BROKERS=kafka:9092

# --- MongoDB Atlas Cloud Configuration ---
# Format: mongodb+srv://<user>:<password>@<cluster>/<db>?...
MONGODB_USER=your_atlas_username
MONGODB_PASSWORD=your_atlas_password
MONGODB_ATLAS_CLUSTER=your_cluster.mongodb.net

# --- MedSync Platform API Keys ---

# AI Symptom Checker (Google Gemini API)
GEMINI_API_KEY=your_gemini_api_key_here

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Notifications (Email/Twilio)
EMAIL_USER=medsync.care@gmail.com
EMAIL_PASS=your_gmail_app_password
TWILIO_SID=AC...
TWILIO_AUTH_TOKEN=your_authToken
TWILIO_FROM=+123456789

# Telemedicine (Agora)
AGORA_APP_ID=your_appId
AGORA_APP_CERTIFICATE=your_appCertificate